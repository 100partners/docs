<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>TG Style Guide — Robotic Minimal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f6f5f1;
    --ink: #0f0f0f;
    --muted: #8a8a85;
    --soft: #d9d8d2;
    --accent: #c2410c;
    --green: #3f7a5e;
    --amber: #b88512;
    --rose:  #b23a5c;
    --indigo:#3a4a9e;
    --white: #ffffff;
    --maxw: 860px;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); }
  body {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13.5px; font-weight: 400; line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 56px 28px 120px; }

  /* Title bar */
  .title-bar {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding: 14px 0; margin-bottom: 48px;
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 11px; text-transform: lowercase; letter-spacing: 0.06em;
    color: var(--muted); flex-wrap: wrap; gap: 8px;
  }
  .title-bar .name { color: var(--ink); font-weight: 700; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; }

  /* Guide sections */
  .g-section { margin-bottom: 56px; }
  .g-kicker {
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 6px; font-weight: 600;
  }
  .g-title {
    font-size: 22px; font-weight: 500; margin: 0 0 6px; line-height: 1.3;
  }
  .g-desc {
    font-size: 12.5px; color: var(--muted); line-height: 1.6; margin-bottom: 24px; max-width: 620px;
  }

  /* Swatches */
  .swatch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }
  .swatch { border: 1px solid var(--ink); overflow: hidden; }
  .swatch .color { height: 72px; }
  .swatch .info { padding: 10px; font-size: 11px; line-height: 1.5; background: var(--bg); }
  .swatch .info .label { font-weight: 600; margin-bottom: 2px; }
  .swatch .info .hex { color: var(--muted); text-transform: uppercase; }
  .swatch .info .css { color: var(--muted); font-size: 10px; }

  /* Type samples */
  .type-row { display: grid; grid-template-columns: 200px 1fr; gap: 20px; padding: 16px 0; border-bottom: 1px dashed var(--soft); align-items: baseline; }
  @media (max-width: 640px) { .type-row { grid-template-columns: 1fr; gap: 4px; } }
  .type-spec { font-size: 10px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.04em; }
  .type-sample-hero { font-size: 26px; font-weight: 500; line-height: 1.35; letter-spacing: -0.01em; }
  .type-sample-section { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: lowercase; color: var(--muted); }
  .type-sample-section b { color: var(--ink); }
  .type-sample-body { font-size: 13.5px; font-weight: 400; line-height: 1.6; }
  .type-sample-meta { font-size: 11px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.06em; }
  .type-sample-stat-k { font-size: 10px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.05em; }
  .type-sample-stat-v { font-size: 14px; font-weight: 500; }
  .type-sample-card-h { font-size: 14px; font-weight: 500; line-height: 1.35; }
  .type-sample-sm { font-size: 12px; line-height: 1.6; color: var(--ink); }
  .type-sample-label { font-size: 10px; letter-spacing: 0.14em; text-transform: lowercase; }

  /* Spacing block */
  .space-demo { display: flex; align-items: stretch; gap: 12px; flex-wrap: wrap; }
  .space-block { border: 1px solid var(--ink); display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding: 0 14px 10px; }
  .space-block .bar { background: var(--accent); width: 24px; }
  .space-block .lbl { font-size: 10px; color: var(--muted); margin-top: 6px; text-align: center; }

  /* Icon row */
  .icon-row { display: flex; gap: 28px; flex-wrap: wrap; align-items: center; }
  .icon-item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .icon-item svg { width: 24px; height: 24px; stroke: var(--ink); stroke-width: 1.25; fill: none; }
  .icon-item .lbl { font-size: 9px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.06em; }

  /* Pattern demos */
  .demo { border: 1px solid var(--ink); padding: 20px; margin-bottom: 14px; background: var(--bg); }
  .demo-label { font-size: 10px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.08em; margin-bottom: 12px; }
  .demo .sec-head { display: flex; align-items: center; gap: 10px; margin-bottom: 0; }
  .demo .sec-head svg { width: 18px; height: 18px; stroke: var(--ink); stroke-width: 1.25; fill: none; flex: none; }
  .demo .sec-head .label { font-size: 11px; letter-spacing: 0.08em; text-transform: lowercase; color: var(--muted); }
  .demo .sec-head .label b { color: var(--ink); font-weight: 600; }
  .demo .sec-head .rule { flex: 1; border-bottom: 1px solid var(--soft); }
  .demo .stat { border: 1px solid var(--ink); padding: 10px 12px; display: inline-block; margin-right: 8px; margin-top: 8px; }
  .demo .stat .k { font-size: 10px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.05em; }
  .demo .stat .v { font-size: 14px; font-weight: 500; margin-top: 2px; }
  .demo .card { border: 1px solid var(--ink); padding: 16px; background: var(--white); display: inline-block; max-width: 260px; vertical-align: top; margin-right: 12px; margin-top: 10px; }
  .demo .card .topstripe { height: 3px; margin: -16px -16px 14px; }
  .demo .card .tag { display: inline-block; font-size: 9px; letter-spacing: 0.14em; text-transform: lowercase; padding: 2px 6px; color: #fff; margin-bottom: 8px; }
  .demo .pill {
    display: inline-block; font-size: 10px; padding: 2px 8px; border: 1px solid var(--accent);
    color: var(--accent); margin-left: 6px;
  }
  .demo button {
    font-family: inherit; font-size: 11px; text-transform: lowercase; letter-spacing: 0.06em;
    background: var(--ink); color: var(--bg); border: none; padding: 8px 14px; cursor: pointer; margin-right: 8px;
  }
  .demo button.ghost { background: transparent; color: var(--ink); border: 1px solid var(--ink); }
  .demo select {
    font-family: inherit; font-size: 11px; background: transparent; border: 1px solid var(--ink);
    padding: 5px 8px; color: var(--ink); text-transform: lowercase;
  }

  .cursor-demo {
    display: inline-block; width: 10px; height: 20px; background: var(--accent);
    vertical-align: -3px; animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* Code block */
  .code { background: var(--ink); color: #e0dfda; padding: 14px 18px; font-size: 12px; line-height: 1.7; overflow-x: auto; margin-top: 14px; }
  .code .comment { color: #6a6a64; }

  /* Divider rule examples */
  .rule-demo { padding: 8px 0; }
  .rule-solid { border-bottom: 1px solid var(--ink); margin-bottom: 10px; }
  .rule-dashed { border-bottom: 1px dashed var(--soft); margin-bottom: 10px; }
  .rule-dotted { border-bottom: 1px dotted var(--soft); margin-bottom: 10px; }
  .rule-label { font-size: 10px; color: var(--muted); margin-bottom: 14px; }

  /* Do / don't */
  .do-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 640px) { .do-grid { grid-template-columns: 1fr; } }
  .do-box { border: 1px solid var(--ink); padding: 16px; }
  .do-box .flag { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 10px; font-weight: 700; }
  .do-box .flag.yes { color: var(--green); }
  .do-box .flag.no { color: var(--accent); }
  .do-box p { font-size: 12px; line-height: 1.6; margin: 0 0 6px; }

  footer {
    margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--ink);
    font-size: 10px; color: var(--muted); text-transform: lowercase; letter-spacing: 0.06em;
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="title-bar">
    <span class="name">TG Brand Style Guide</span>
    <span>robotic minimal · v1.0 · april 2026</span>
  </div>

  <!-- ========== 01. IDENTITY ========== -->
  <div class="g-section">
    <div class="g-kicker">01 · identity</div>
    <div class="g-title">design philosophy</div>
    <div class="g-desc">
      Robotic Minimal. Inspired by developer tooling, terminal interfaces, markdown file trees, and newspaper editorial design.
      Every element earns its place through function. Whitespace is the primary design element. Typography carries all the weight.
      Color is restrained and intentional. Decoration is structural, not ornamental: thin-stroke SVG icons, dashed rules, bracket syntax.
    </div>

    <div class="do-grid">
      <div class="do-box">
        <div class="flag yes">do</div>
        <p>Use whitespace generously. Let sections breathe.</p>
        <p>Keep all text lowercase. Exceptions: proper nouns, acronyms.</p>
        <p>Lean on borders, rules, and spacing over background fills.</p>
        <p>Use code-inspired syntax: brackets, dots, slashes, arrows.</p>
      </div>
      <div class="do-box">
        <div class="flag no">don't</div>
        <p>Use gradients, shadows, rounded corners, or glows.</p>
        <p>Use more than one accent color per section.</p>
        <p>Use Title Case or ALL CAPS for body text.</p>
        <p>Add illustration or imagery that isn't line-art or structural.</p>
      </div>
    </div>
  </div>

  <!-- ========== 02. COLOR ========== -->
  <div class="g-section">
    <div class="g-kicker">02 · color</div>
    <div class="g-title">palette</div>
    <div class="g-desc">
      A restrained system built on two primaries (ink and paper) with one accent. Four semantic colors for categorical data.
      Background is warm off-white, never pure #fff. Ink is near-black, never pure #000. Muted tone sits between for secondary text.
    </div>

    <div class="swatch-grid">
      <div class="swatch">
        <div class="color" style="background:#f6f5f1;border-bottom:1px solid #d9d8d2;"></div>
        <div class="info"><div class="label">paper</div><div class="hex">#f6f5f1</div><div class="css">--bg</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#0f0f0f;"></div>
        <div class="info"><div class="label">ink</div><div class="hex">#0f0f0f</div><div class="css">--ink, --line</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#8a8a85;"></div>
        <div class="info"><div class="label">muted</div><div class="hex">#8a8a85</div><div class="css">--muted</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#d9d8d2;"></div>
        <div class="info"><div class="label">soft</div><div class="hex">#d9d8d2</div><div class="css">--soft</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#ffffff;border-bottom:1px solid #d9d8d2;"></div>
        <div class="info"><div class="label">white (cards)</div><div class="hex">#ffffff</div><div class="css">card bg only</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#c2410c;"></div>
        <div class="info"><div class="label">accent / burnt orange</div><div class="hex">#c2410c</div><div class="css">--accent</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#3f7a5e;"></div>
        <div class="info"><div class="label">green / health</div><div class="hex">#3f7a5e</div><div class="css">--green</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#b88512;"></div>
        <div class="info"><div class="label">amber / wealth</div><div class="hex">#b88512</div><div class="css">--amber</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#b23a5c;"></div>
        <div class="info"><div class="label">rose / love</div><div class="hex">#b23a5c</div><div class="css">--rose</div></div>
      </div>
      <div class="swatch">
        <div class="color" style="background:#3a4a9e;"></div>
        <div class="info"><div class="label">indigo / happiness</div><div class="hex">#3a4a9e</div><div class="css">--indigo</div></div>
      </div>
    </div>

    <div style="margin-top:24px;">
      <div class="g-desc" style="margin-bottom:12px;">Color usage rules:</div>
      <div class="do-grid">
        <div class="do-box">
          <div class="flag yes">primary system</div>
          <p><b>ink (#0f0f0f)</b> — all primary text, borders, filled progress bars, icons</p>
          <p><b>paper (#f6f5f1)</b> — page background, never pure white</p>
          <p><b>muted (#8a8a85)</b> — labels, metadata, secondary text, timestamps</p>
          <p><b>soft (#d9d8d2)</b> — dashed section dividers, dotted borders, subtle rules</p>
        </div>
        <div class="do-box">
          <div class="flag yes">accent system</div>
          <p><b>accent (#c2410c)</b> — blinking cursor, current-state indicators, pills, primary action tags, active hour, priority numbers</p>
          <p><b>green (#3f7a5e)</b> — positive values, health category, good-news tag</p>
          <p><b>amber (#b88512)</b> — wealth category, financial highlights</p>
          <p><b>rose (#b23a5c)</b> — love/relationship category</p>
          <p><b>indigo (#3a4a9e)</b> — happiness/padel category</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== 03. TYPOGRAPHY ========== -->
  <div class="g-section">
    <div class="g-kicker">03 · typography</div>
    <div class="g-title">type system</div>
    <div class="g-desc">
      One font family for everything: JetBrains Mono. Weight, size, spacing, and case do all the hierarchical work.
      All interface text is lowercase unless it's a proper noun. No serif companion. No sans-serif fallback that "looks different."
      Monospace is the identity.
    </div>

    <div class="type-row">
      <div class="type-spec">hero headline<br>26px / 500 / -0.01em<br>line-height: 1.35</div>
      <div class="type-sample-hero">today is built, not found.<span class="cursor-demo"></span></div>
    </div>
    <div class="type-row">
      <div class="type-spec">section header<br>11px / 600 kicker + 400 label<br>letter-spacing: 0.08em</div>
      <div class="type-sample-section">[<b>section</b>] label.context · src: tool</div>
    </div>
    <div class="type-row">
      <div class="type-spec">body text<br>13.5px / 400<br>line-height: 1.6</div>
      <div class="type-sample-body">Most agent failures aren't reasoning failures, they're context failures. The model is asked to act on incomplete or noisy information.</div>
    </div>
    <div class="type-row">
      <div class="type-spec">metadata / eyebrow<br>11px / 400<br>letter-spacing: 0.06em</div>
      <div class="type-sample-meta">// good morning, tg · apr 14, 2026 · 3 min read</div>
    </div>
    <div class="type-row">
      <div class="type-spec">stat label<br>10px / 400<br>letter-spacing: 0.05em</div>
      <div><span class="type-sample-stat-k">net.worth</span><br><span class="type-sample-stat-v">$428,940</span></div>
    </div>
    <div class="type-row">
      <div class="type-spec">card headline<br>14px / 500<br>line-height: 1.35</div>
      <div class="type-sample-card-h">Claude Sonnet 4.6 ships with big tool-use gains</div>
    </div>
    <div class="type-row">
      <div class="type-spec">card body<br>12px / 400<br>line-height: 1.6</div>
      <div class="type-sample-sm">Sonnet 4.6 drops overnight: +7 pts on SWE-bench and a 40% reduction in malformed tool calls.</div>
    </div>
    <div class="type-row">
      <div class="type-spec">tag / pill<br>9-10px / 400-600<br>letter-spacing: 0.14em</div>
      <div class="type-sample-label">ai · claude &nbsp;&nbsp; good news &nbsp;&nbsp; apply today</div>
    </div>

    <div style="margin-top: 24px;">
      <div class="g-desc" style="margin-bottom:8px;">Font stack (CSS):</div>
      <div class="code">
        <span class="comment">/* Primary — only font in the system */</span><br>
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;<br><br>
        <span class="comment">/* Weights used */</span><br>
        300 — light (not currently used, reserved for large display)<br>
        400 — regular (body, metadata, labels)<br>
        500 — medium (headlines, stat values, card titles)<br>
        600 — semibold (kickers, logo, bold labels)<br>
        700 — bold (reserved for maximum emphasis)
      </div>
    </div>
  </div>

  <!-- ========== 04. SPACING ========== -->
  <div class="g-section">
    <div class="g-kicker">04 · spacing</div>
    <div class="g-title">spacing + layout</div>
    <div class="g-desc">
      Max content width: 820px. Page padding: 56px top, 28px sides, 120px bottom.
      Spacing scale is intentionally tight. Dense but not cramped. Generous vertical rhythm between sections (40px), tight within (10-14px).
    </div>

    <div class="space-demo">
      <div class="space-block" style="width:60px;"><div class="bar" style="height:4px;"></div><div class="lbl">4px<br>micro</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:8px;"></div><div class="lbl">8px<br>tight</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:12px;"></div><div class="lbl">12px<br>gap</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:14px;"></div><div class="lbl">14px<br>item</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:20px;"></div><div class="lbl">20px<br>inset</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:28px;"></div><div class="lbl">28px<br>section</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:40px;"></div><div class="lbl">40px<br>block</div></div>
      <div class="space-block" style="width:60px;"><div class="bar" style="height:56px;"></div><div class="lbl">56px<br>page top</div></div>
    </div>

    <div style="margin-top:24px;">
      <div class="g-desc" style="margin-bottom:8px;">Layout grid:</div>
      <div class="code">
        max-width: 820px;<br>
        page padding: 56px 28px 120px;<br>
        section padding: 40px 0;<br>
        grid gaps: 12px (stats), 14px (cards, pillars);<br>
        stat boxes: 10px 12px inner padding;<br>
        card inner padding: 16px;<br><br>
        <span class="comment">/* Responsive breakpoints */</span><br>
        820px — signal cards stack to 1 column<br>
        720px — 2-column layouts collapse<br>
        640px — stat grids to 2-up, all typography scales down
      </div>
    </div>
  </div>

  <!-- ========== 05. BORDERS + DIVIDERS ========== -->
  <div class="g-section">
    <div class="g-kicker">05 · borders + dividers</div>
    <div class="g-title">structural lines</div>
    <div class="g-desc">
      Lines are the primary decorative element. Three tiers of visual weight, each with a specific role.
      No border-radius anywhere. All corners are sharp 0px.
    </div>

    <div class="rule-demo">
      <div class="rule-solid"></div>
      <div class="rule-label">1px solid var(--ink) — structural: masthead, footer, stat boxes, card borders, section first/last</div>
      <div class="rule-dashed" style="margin-top:18px;"></div>
      <div class="rule-label">1px dashed var(--soft) — sectional: between major sections, within cards, between items</div>
      <div class="rule-dotted" style="margin-top:18px;"></div>
      <div class="rule-label">1px dotted var(--soft) — detail: between list items, inside agenda, sub-separators</div>
    </div>

    <div class="code" style="margin-top:16px;">
      <span class="comment">/* Border rules */</span><br>
      border-radius: 0px; <span class="comment">/* everywhere, always */</span><br>
      border-color: var(--ink); <span class="comment">/* primary containers */</span><br>
      border-color: var(--soft); <span class="comment">/* inner dividers */</span><br>
      border-color: var(--accent); <span class="comment">/* pills and active indicators only */</span><br>
    </div>
  </div>

  <!-- ========== 06. ICONOGRAPHY ========== -->
  <div class="g-section">
    <div class="g-kicker">06 · iconography</div>
    <div class="g-title">line icons</div>
    <div class="g-desc">
      All icons are custom inline SVGs. 18x18px display size. 1.25px stroke weight. Stroke only, no fills (except chess board pattern and small indicator dots).
      Icons appear only in section headers, always left of the bracket label.
    </div>

    <div class="icon-row">
      <div class="icon-item">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="1"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="16" y1="3" x2="16" y2="7"/></svg>
        <span class="lbl">agenda</span>
      </div>
      <div class="icon-item">
        <svg viewBox="0 0 24 24"><polyline points="4,12 10,18 20,6"/></svg>
        <span class="lbl">priorities</span>
      </div>
      <div class="icon-item">
        <svg viewBox="0 0 24 24"><path d="M4 4h12a4 4 0 0 1 4 4v12H8a4 4 0 0 1-4-4z"/><line x1="4" y1="8" x2="20" y2="8"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
        <span class="lbl">scripture</span>
      </div>
      <div class="icon-item">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="14" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><circle cx="7" cy="6.5" r="0.5" fill="currentColor"/><circle cx="10" cy="6.5" r="0.5" fill="currentColor"/><line x1="7" y1="13" x2="17" y2="13"/><line x1="7" y1="15.5" x2="14" y2="15.5"/></svg>
        <span class="lbl">signal</span>
      </div>
      <div class="icon-item">
